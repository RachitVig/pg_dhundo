# ══════════════════════════════════════════════════════════════════════════════
# PG DHUNDO — BACKEND ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked with  <-- REQUIRED
#   3. NEVER commit .env to Git — it is already in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# LOCAL DEV (plain Postgres):
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pg_dhundo
#
# NEON (recommended free cloud DB):
#   DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#
# SUPABASE (alternative):
#   DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pg_dhundo   # <-- REQUIRED

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be a long, random, unpredictable string.
# Generate one:  python -c "import secrets; print(secrets.token_hex(48))"
#
# ⚠  NEVER use a simple string like "admin123" in production.
#
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_48_CHARS   # <-- REQUIRED

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# NO trailing slashes.
#
# LOCAL DEV:
#   ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# PRODUCTION (replace with your actual Vercel domain):
#   ALLOWED_ORIGINS=https://pg-dhundo.vercel.app
#
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173   # <-- REQUIRED

# ── Runtime Mode ──────────────────────────────────────────────────────────────
# Controls logging verbosity and debug behaviour.
# Values: "development" | "production"
#
ENVIRONMENT=development   # <-- REQUIRED  (change to "production" on Render)

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Used for:  Forgot Password emails, Booking inquiry notifications.
#
# GMAIL SETUP (recommended free option):
#   1. Enable 2-Factor Authentication on your Google account.
#   2. Go to: Google Account → Security → App Passwords.
#   3. Create a new App Password (select "Mail" / "Other").
#   4. Use the 16-character code as SMTP_PASSWORD — NOT your Gmail login password.
#
# GMAIL EXAMPLE:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx
#
# ⚠  If these are left blank the app will print email content to the terminal
#    instead of sending — safe for local development.
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                 # <-- REQUIRED for real emails (your Gmail address)
SMTP_PASSWORD=             # <-- REQUIRED for real emails (Gmail App Password, 16 chars)
